<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- FONDO: degradado radial negro profundo -->
    <path
        android:pathData="M54,54m-54,0a54,54 0 1,0 108,0a54,54 0 1,0 -108,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="54">
                <item android:offset="0" android:color="#2A2A2A"/>
                <item android:offset="0.6" android:color="#1A1A1A"/>
                <item android:offset="1" android:color="#000000"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ANILLO EXTERIOR: degradado naranja dorado (sweep corregido) -->
    <path
        android:fillColor="#00000000"
        android:strokeWidth="4.5"
        android:pathData="M54,54m-50,0a50,50 0 1,0 100,0a50,50 0 1,0 -100,0">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="sweep"
                android:centerX="54"
                android:centerY="54">
                <item android:offset="0"   android:color="#FF6B00"/>
                <item android:offset="0.4" android:color="#FFAA00"/>
                <item android:offset="0.7" android:color="#FF8C00"/>
                <item android:offset="1"   android:color="#FF6B00"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ANILLO INTERIOR: naranja fino -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FF6B00"
        android:strokeWidth="0.8"
        android:strokeAlpha="0.5"
        android:pathData="M54,54m-44,0a44,44 0 1,0 88,0a44,44 0 1,0 -88,0"/>

    <!-- LETRA H: glow halo morado -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#7C3AED"
        android:strokeWidth="3.5"
        android:strokeAlpha="0.35"
        android:pathData="M28,22 L28,86 L38,86 L38,58 L70,58 L70,86 L80,86 L80,22 L70,22 L70,48 L38,48 L38,22 Z"/>

    <!-- LETRA H: cuerpo con degradado -->
    <path
        android:pathData="M28,22 L28,86 L38,86 L38,58 L70,58 L70,86 L80,86 L80,22 L70,22 L70,48 L38,48 L38,22 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="28"
                android:startY="22"
                android:endX="28"
                android:endY="86">
                <item android:offset="0"   android:color="#9F5FFF"/>
                <item android:offset="0.5" android:color="#7B2FE0"/>
                <item android:offset="1"   android:color="#3D0D99"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ESQUINAS BISELADAS -->
    <path android:fillColor="#000000" android:pathData="M28,22 L36,22 L28,30 Z"/>
    <path android:fillColor="#000000" android:pathData="M80,22 L72,22 L80,30 Z"/>
    <path android:fillColor="#000000" android:pathData="M28,86 L36,86 L28,78 Z"/>
    <path android:fillColor="#000000" android:pathData="M80,86 L72,86 L80,78 Z"/>

    <!-- REFLEJO METÁLICO -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.2"
        android:strokeAlpha="0.25"
        android:pathData="M29,23 L29,85 M38,49 L70,49 M71,23 L71,47"/>

</vector>
